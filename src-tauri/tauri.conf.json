{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DetDoc",
  "version": "0.1.0",
  "identifier": "dev.detdoc.gui",
  "build": {
    "beforeDevCommand": "npm run gui:vite",
    "beforeBuildCommand": "npm run gui:vite:build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist-ui"
  },
  "app": {
    "windows": [
      {
        "title": "DetDoc",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 720
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
